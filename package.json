{
  "name": "with-npm",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/integrations/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "postinstall": "patch-package && node scripts/fix-next-postcss.mjs && npm dedupe --ignore-scripts"
  },
  "devDependencies": {
    "ajv": "^6.15.0",
    "patch-package": "^8.0.1",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "turbo": "^2.9.14"
  },
  "overrides": {
    "ajv": "^6.15.0",
    "zod": "4.4.3",
    "next": {
      "postcss": "^8.5.14"
    }
  },
  "packageManager": "npm@10.5.0",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
