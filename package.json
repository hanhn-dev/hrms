{
  "name": "with-npm",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "turbo": "^2.9.12"
  },
  "overrides": {
    "postcss": "^8.5.14",
    "ajv": "^6.15.0",
    "next": {
      "postcss": "^8.5.14"
    }
  },
  "packageManager": "npm@10.5.0",
  "engines": {
    "node": ">=18"
  }
}
